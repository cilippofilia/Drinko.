    "Remember to add the juice of the peeled fruits used to make superjuice. The final volume will be a bit higher than the water volume displayed." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Denken Sie daran, den Saft der geschälten Früchte hinzuzufügen, aus denen Superjuice hergestellt wird. Das Endvolumen wird etwas höher sein als das angezeigte Wasservolumen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remember to add the juice of the peeled fruits used to make superjuice. The final volume will be a bit higher than the water volume displayed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuerda añadir el jugo de las frutas peladas usadas para hacer superjuice. El volumen final será un poco mayor que el volumen de agua mostrado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pensez à ajouter le jus des fruits pelés utilisés pour faire du superjus. Le volume final sera un peu supérieur au volume d'eau affiché."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ricordati di aggiungere il succo della frutta sbucciata utilizzata per preparare il Superjuice. Il volume finale sarà leggermente superiore al volume dell'acqua visualizzato."
          }
        }
      }
    },
